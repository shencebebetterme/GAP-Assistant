{
  "name": "gap-assist",
  "displayName": "GAP Assist",
  "description": "Language intelligence, reference hovers, static analysis, and debugging for GAP.",
  "version": "0.5.3",
  "publisher": "shencebebetterme",
  "license": "GPL-2.0-or-later",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/shencebebetterme/GAP-Assist.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "gap",
    "group theory",
    "algebra",
    "syntax highlighting",
    "hover"
  ],
  "activationEvents": [
    "onLanguage:gap",
    "onCommand:gapReference.openLocalManual",
    "onCommand:gapReference.debugCurrentFile",
    "onCommand:gapReference.debugCurrentNotebookCell",
    "onCommand:gapReference.openSemanticObjects",
    "onCommand:gapReference.inspectSemanticObject",
    "onView:gapSemanticObjects",
    "onDebugResolve:gap"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gap",
        "aliases": [
          "GAP",
          "gap"
        ],
        "extensions": [
          ".g",
          ".gap",
          ".gd",
          ".gi",
          ".tst"
        ],
        "filenames": [
          "init.g",
          "read.g"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gap",
        "scopeName": "source.gap",
        "path": "./syntaxes/gap.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "gap",
        "label": "GAP",
        "languages": [
          "gap"
        ],
        "program": "./debug/gapDebugAdapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "gap"
                ],
                "description": "Debugger type."
              },
              "request": {
                "type": "string",
                "enum": [
                  "launch"
                ],
                "description": "Debug request type."
              },
              "name": {
                "type": "string",
                "description": "Debug configuration name."
              },
              "program": {
                "type": "string",
                "default": "${file}",
                "description": "GAP source file to debug."
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false,
                "description": "Stop at the first executable GAP statement."
              },
              "gapCommand": {
                "type": "string",
                "default": "",
                "description": "Optional GAP executable command. Leave empty to use wsl on Windows and gap elsewhere."
              },
              "gapArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Optional GAP command arguments. Leave empty to use quiet mode with a wide output line width."
              },
              "maxValueLength": {
                "type": "number",
                "default": 4000,
                "minimum": 200,
                "maximum": 50000,
                "description": "Maximum number of characters captured for each runtime value."
              },
              "breakpoints": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "default": [],
                "description": "Internal breakpoint handoff used by GAP: Debug Current File."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "gap",
            "request": "launch",
            "name": "Debug GAP File",
            "program": "${file}",
            "stopOnEntry": false
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "gap"
      }
    ],
    "views": {
      "debug": [
        {
          "id": "gapSemanticObjects",
          "type": "webview",
          "name": "GAP Objects"
        }
      ]
    },
    "commands": [
      {
        "command": "gapReference.openLocalManual",
        "title": "GAP: Open Local Reference Page"
      },
      {
        "command": "gapReference.debugCurrentFile",
        "title": "Debug Current File",
        "category": "GAP"
      },
      {
        "command": "gapReference.debugCurrentNotebookCell",
        "title": "Debug Current Notebook Cell",
        "shortTitle": "Debug Cell",
        "icon": "$(debug-alt-small)",
        "category": "GAP"
      },
      {
        "command": "gapReference.openSemanticObjects",
        "title": "Open Object Inspector",
        "category": "GAP"
      },
      {
        "command": "gapReference.inspectSemanticObject",
        "title": "Inspect in GAP Objects",
        "category": "GAP"
      }
    ],
    "menus": {
      "debug/variables/context": [
        {
          "command": "gapReference.inspectSemanticObject",
          "when": "debugConfigurationType == gap && debugProtocolVariableMenuContext == gapSemanticObject",
          "group": "1_view"
        }
      ],
      "editor/title/run": [
        {
          "command": "gapReference.debugCurrentFile",
          "when": "resourceLangId == gap",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "gapReference.debugCurrentFile",
          "when": "resourceLangId == gap",
          "group": "navigation"
        }
      ],
      "notebook/cell/title": [
        {
          "command": "gapReference.debugCurrentNotebookCell",
          "when": "notebookType == jupyter-notebook && isWorkspaceTrusted && notebookCellType == code && notebookKernel =~ /[Gg][Aa][Pp]/",
          "group": "debug@0"
        }
      ],
      "notebook/cell/execute": [
        {
          "command": "gapReference.debugCurrentNotebookCell",
          "when": "notebookType == jupyter-notebook && isWorkspaceTrusted && notebookCellType == code && notebookKernel =~ /[Gg][Aa][Pp]/",
          "group": "jupyterCellExecute@0"
        }
      ]
    },
    "configuration": {
      "title": "GAP Assist",
      "properties": {
        "gapReference.gapInstallationPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the local GAP installation directory. Reference links use doc/ref and package links use pkg/* manual paths inside this directory unless gapReference.manualPath is set for the reference manual."
        },
        "gapReference.manualPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the GAP reference manual HTML directory. Leave empty to use gapReference.gapInstallationPath + doc/ref. Package manual links still use gapReference.gapInstallationPath when available."
        },
        "gapReference.hover.maxEntries": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of overload/reference entries to show in one hover."
        },
        "gapReference.hover.maxDescriptionLength": {
          "type": "number",
          "default": 900,
          "minimum": 160,
          "maximum": 4000,
          "description": "Maximum description length per hover entry before truncation."
        },
        "gapReference.hover.wrapColumn": {
          "type": "number",
          "default": 86,
          "minimum": 40,
          "maximum": 140,
          "description": "Column at which hover signatures and documentation paragraphs are hard-wrapped."
        },
        "gapReference.hover.maxExamples": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 5,
          "description": "Maximum number of GAP example blocks to show in one hover entry."
        },
        "gapReference.hover.maxExampleLines": {
          "type": "number",
          "default": 14,
          "minimum": 2,
          "maximum": 80,
          "description": "Maximum number of lines to show from each GAP example block."
        },
        "gapReference.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight documented GAP reference symbols using VS Code semantic tokens."
        }
      }
    }
  },
  "scripts": {
    "extract-declarations": "node scripts/extract-gap-declarations.js",
    "extract-docs": "node scripts/extract-gap-docs.js",
    "language-server": "node server/lsp-server.js",
    "test": "node scripts/test-parser.js && node scripts/test-analyzer.js && node scripts/test-lsp-server.js && node scripts/test-lsp-client.js && node scripts/test-extension-helpers.js && node scripts/test-debug-instrumenter.js && node scripts/test-debug-adapter.js",
    "validate": "node scripts/validate-extension.js && npm test",
    "vscode:prepublish": "npm run validate"
  }
}
